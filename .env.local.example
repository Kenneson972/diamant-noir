# Variables d'environnement pour Diamant Noir
# Copiez ce fichier en .env.local et remplissez les valeurs

# ============================================
# SUPABASE (OBLIGATOIRE)
# ============================================
# Récupérez ces valeurs dans Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_ici

# Clé service role (pour les opérations admin côté serveur)
# ⚠️ NE JAMAIS EXPOSER CETTE CLÉ DANS LE CODE CLIENT
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role_ici

# ============================================
# STRIPE (Optionnel - pour les paiements)
# ============================================
STRIPE_SECRET_KEY=sk_test_votre_cle_stripe
STRIPE_WEBHOOK_SECRET=whsec_votre_webhook_secret

# ============================================
# CHATBOT (Optionnel - pour les réponses IA)
# ============================================
N8N_WEBHOOK_URL=https://votre-n8n.com/webhook/diamant-noir
# OU
CHAT_WEBHOOK_URL=https://votre-service-ia.com/api/chat

# Copilot propriétaire (dashboard /dashboard/proprio/assistant) — prioritaire sur N8N_WEBHOOK_URL pour cette route
# N8N_OWNER_WEBHOOK_URL=https://votre-n8n.com/webhook/diamant-owner
# Optionnel : même secret côté n8n (IF sur le header) pour sécuriser le webhook
# N8N_OWNER_WEBHOOK_SECRET=un-secret-long-partagé

# Assistant gérant POST /api/admin/chat — Bearer obligatoire + allowlist (emails et/ou UUID Supabase, séparés par virgules)
# Sans ces variables, la route admin chat répond 403 (séparation propriétaire / équipe).
# ADMIN_CHAT_ALLOWED_EMAILS=chef@agence.com,ops@agence.com
# ADMIN_CHAT_ALLOWED_USER_IDS=uuid-supabase-1,uuid-supabase-2

# ============================================
# IMPORT ANNONCE (dashboard proprio → « Import annonce »)
# ============================================
# Optionnel : fragments de hostname supplémentaires (séparés par virgule), en plus de Airbnb/Booking/Vrbo/Abritel…
# LISTING_IMPORT_EXTRA_HOST_FRAGMENTS=tripadvisor.co.uk
#
# Dangereux en production : autorise tout domaine « public » (garde-fous SSRF : pas de localhost / IP privées).
# LISTING_IMPORT_ALLOW_ANY_PUBLIC_URL=0
#
# Enrichissement IA — priorité n8n si défini, sinon OpenAI direct.
# LISTING_IMPORT_N8N_WEBHOOK_URL=https://votre-n8n.com/webhook/diamant-noir-listing-import
# LISTING_IMPORT_N8N_WEBHOOK_SECRET=
# LISTING_IMPORT_OPENAI_API_KEY=
# LISTING_IMPORT_OPENAI_MODEL=gpt-4o-mini

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Pages légales (confidentialité, cookies, CGU) : mettre à 1 pour l’ancienne mise en page
# une colonne simple (fallback). Laisser vide ou 0 pour le style « landing » à sections.
# NEXT_PUBLIC_MARKETING_SIMPLE_LEGAL=1
