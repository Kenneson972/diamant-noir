# Variables d'environnement pour Diamant Noir
# Copiez ce fichier en .env.local et remplissez les valeurs

# ============================================
# SUPABASE (OBLIGATOIRE)
# ============================================
# Récupérez ces valeurs dans Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_ici

# Clé service role (pour les opérations admin côté serveur)
# ⚠️ NE JAMAIS EXPOSER CETTE CLÉ DANS LE CODE CLIENT
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role_ici

# ============================================
# STRIPE (Optionnel - pour les paiements)
# ============================================
STRIPE_SECRET_KEY=sk_test_votre_cle_stripe
STRIPE_WEBHOOK_SECRET=whsec_votre_webhook_secret

# ============================================
# CHATBOT (Optionnel - pour les réponses IA)
# ============================================
N8N_WEBHOOK_URL=https://votre-n8n.com/webhook/diamant-noir
N8N_WEBHOOK_SECRET=votre_secret_webhook_n8n
# OU
CHAT_WEBHOOK_URL=https://votre-service-ia.com/api/chat

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Sécurité routes internes
TEAM_DASH_SECRET=definir_un_secret_long_et_unique
SYNC_CRON_SECRET=definir_un_secret_cron_long_et_unique

# Pages légales (confidentialité, cookies, CGU) : mettre à 1 pour l’ancienne mise en page
# une colonne simple (fallback). Laisser vide ou 0 pour le style « landing » à sections.
# NEXT_PUBLIC_MARKETING_SIMPLE_LEGAL=1
