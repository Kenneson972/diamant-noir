      "position": [580, 80]
    },
    {
      "parameters": {
        "toolDescription": "Santé des synchronisations OTA (Airbnb / Booking) des villas du propriétaire.",
        "method": "GET",
        "url": "https://VOTRE-DOMAINE-KAYVILA/api/dashboard/ota-status",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Authorization", "value": "=Bearer {{ $('Code - Auth JWT').first().json.token }}" } ] },
        "options": {}
      },
      "id": "b1-tool-ota",
      "name": "kayvila-ota-status",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [720, 80]
    },
    {
      "parameters": {
        "jsCode": "const i = $input.first().json;\nlet t = i.output || i.text || \"Désolé, je rencontre un souci technique.\";\nt = t.replace(/\\*\\*(.*?)\\*\\*/g, '$1').replace(/^[ \\t]*#+[ \\t]+/gm, '').replace(/^[ \\t]*-+[ \\t]+/gm, '• ').trim();\nreturn [{ json: { response: t, sessionId: $('Code - Auth JWT').first().json.sessionId, userId: $('Code - Auth JWT').first().json.userId } }];"
      },
      "id": "b1-format",
      "name": "FORMAT RESPONSE",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [280, -200]
    },
    {
      "parameters": {
        "jsCode": "const msg = ($('Code - Auth JWT').first().json.userMessage || '').toLowerCase();\nconst urgentKw = ['urgent', 'retard', 'annul', 'conflit', 'problème', 'probleme', 'panne', 'litige', 'check-in', 'checkin', 'aujourd', 'ce soir', 'demain', 'ménage pas fait', 'menage pas fait'];\nconst isUrgent = urgentKw.some(k => msg.includes(k));\nreturn [{ json: { isUrgent: isUrgent ? 'true' : 'false', userId: $('Code - Auth JWT').first().json.userId, message: $('Code - Auth JWT').first().json.userMessage, aiOutput: ($('AI Agent').first().json.output || '') } }];"
      },
      "id": "b1-summary",
      "name": "PREPARE SUMMARY PROMPT",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [280, -440]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 1 },
          "conditions": [
            { "id": "b1-c-urg", "leftValue": "={{ $json.isUrgent }}", "rightValue": "true", "operator": { "type": "string", "operation": "equals" } }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "b1-if-urgent",
      "name": "IF - Urgent ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [500, -440]
    },
    {
      "parameters": {
        "chatId": "={{ $vars.TELEGRAM_OWNER_CHAT_ID || 'REMPLACER_CHAT_ID' }}",
        "text": "=⚠️ Kayvila — Demande urgente d'un propriétaire\n\nProprio: {{ $json.userId }}\nMessage: {{ $json.message }}",
        "additionalFields": {}
      },
      "id": "b1-telegram",
      "name": "Telegram - Alerte Proprio",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [720, -440],
      "credentials": {
        "telegramApi": { "id": "REPLACE_TELEGRAM", "name": "KAYVILA TELEGRAM" }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "b1-s-sid", "name": "session_id", "value": "={{ $json.sessionId }}", "type": "string" },
            { "id": "b1-s-user", "name": "conversation_data.user", "value": "={{ $('Code - Auth JWT').first().json.userMessage }}", "type": "string" },
            { "id": "b1-s-ai", "name": "conversation_data.assistant", "value": "={{ $json.response }}", "type": "string" },
            { "id": "b1-s-meta", "name": "metadata", "value": "={{ { \"session_id\": $json.sessionId, \"agent\": \"proprietaire\", \"user_id\": $json.userId } }}", "type": "object" }
          ]
        },
        "options": {}
      },
