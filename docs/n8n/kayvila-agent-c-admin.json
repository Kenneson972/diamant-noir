    {
      "parameters": {
        "jsCode": "const raw = ($('Webhook').first().json.body.token || $('Webhook').first().json.headers?.authorization || '').replace(/^Bearer\\s+/i, '');\nlet userId = '', role = '';\ntry {\n  const payload = JSON.parse(Buffer.from(raw.split('.')[1] || '', 'base64').toString('utf8'));\n  userId = payload.sub || payload.user_id || payload.userId || '';\n  role = payload.role || (payload.user_metadata && payload.user_metadata.role) || (payload.app_metadata && payload.app_metadata.role) || '';\n} catch (e) {}\nconst body = $('Webhook').first().json.body;\nconst valid = !!userId && String(role).toLowerCase() === 'admin';\nreturn [{ json: { userId, role, token: raw, sessionId: body.sessionid || ('admin-' + userId), userMessage: body.message || '', valid: valid ? 'true' : 'false' } }];"
      },
