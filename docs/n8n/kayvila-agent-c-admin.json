    {
      "parameters": {
        "jsCode": "const msg = ($('Code - Auth JWT').first().json.userMessage || '').toLowerCase();\nconst out = ($('AI Agent').first().json.output || '').toLowerCase();\nconst blob = msg + ' ' + out;\nconst criticalKw = ['panne', 'impayé', 'impaye', 'litige', 'erreur', 'échec', 'echec', 'bloqué', 'bloque', 'down', 'critique', 'anomalie', 'conflit'];\nconst submKw = ['soumission', 'submission', 'à valider', 'a valider', 'en attente', 'nouvelle villa', 'validation'];\nconst isCritical = criticalKw.some(k => blob.includes(k));\nconst hasSubmission = submKw.some(k => blob.includes(k));\nreturn [{ json: { isCritical: isCritical ? 'true' : 'false', hasSubmission: hasSubmission ? 'true' : 'false', message: $('Code - Auth JWT').first().json.userMessage, aiOutput: $('AI Agent').first().json.output || '' } }];"
      },
